 i18n.js
 Internacionalização (i18n)
=========================================================*/

import Storage from "../js/storage.js";
import EventBus from "../js/event-bus.js";
import Analytics from "../js/analytics.js";

class I18n {

    constructor() {

        this.defaultLanguage = "pt-BR";

        this.currentLanguage = this.defaultLanguage;

        this.languages = new Map();

        this.dictionary = {};

        this.loaded = false;

    }

    /*=====================================================
      INITIALIZE
    =====================================================*/

    async initialize(language = null) {

        this.currentLanguage =

            language ||

            Storage.get(

                "language",

                this.defaultLanguage

            );

        await this.load(

            this.currentLanguage

        );

    }

    /*=====================================================
      LOAD
    =====================================================*/

    async load(language) {

        if (

            this.languages.has(language)

        ) {

            this.dictionary =

                this.languages.get(language);

            this.currentLanguage = language;

            this.translatePage();

            return;

        }

        try {

            const response =

                await fetch(

                    `i18n/${language}.json`

                );

            if (!response.ok)

                throw new Error(language);

            const json =

                await response.json();

            this.languages.set(

                language,

                json

            );

            this.dictionary = json;

            this.currentLanguage = language;

            Storage.set(

                "language",

                language

            );

            this.loaded = true;

            this.translatePage();

            EventBus.emit(

                "i18n:changed",

                language

            );

            Analytics.event(

                "language_changed",

                language

            );

        }

        catch (e) {

            console.warn(

                "Idioma não encontrado:",

                language

            );

            if (

                language !==

                this.defaultLanguage

            ) {

                return this.load(

                    this.defaultLanguage

                );

            }

        }

    }

    /*=====================================================
      TRANSLATE
    =====================================================*/

    t(key, params = {}) {

        let value =

            this.dictionary[key] ||

            key;

        Object.entries(params)

            .forEach(

                ([k, v]) => {

                    value =

                        value.replace(

                            `{${k}}`,

                            v

                        );

                }

            );

        return value;

    }

    /*=====================================================
      PAGE
    =====================================================*/

    translatePage() {

        document

            .querySelectorAll(

                "[data-i18n]"

            )

            .forEach(

                element => {

                    const key =

                        element.dataset.i18n;

                    element.innerHTML =

                        this.t(key);

                }

            );

        document

            .querySelectorAll(

                "[data-i18n-placeholder]"

            )

            .forEach(

                element => {

                    const key =

                        element.dataset.i18nPlaceholder;

                    element.placeholder =

                        this.t(key);

                }

            );

        document

            .querySelectorAll(

                "[data-i18n-title]"

            )

            .forEach(

                element => {

                    const key =

                        element.dataset.i18nTitle;

                    element.title =

                        this.t(key);

                }

            );

    }

    /*=====================================================
      CHANGE
    =====================================================*/

    async change(language) {

        await this.load(language);

    }

    /*=====================================================
      GET CURRENT
    =====================================================*/

    current() {

        return this.currentLanguage;

    }

    /*=====================================================
      AVAILABLE
    =====================================================*/

    available() {

        return [

            {

                code:"pt-BR",

                name:"Português"

            },

            {

                code:"en-US",

                name:"English"

            },

            {

                code:"es-ES",

                name:"Español"

            },

            {

                code:"ja-JP",

                name:"日本語"

            }

        ];

    }

    /*=====================================================
      HAS
    =====================================================*/

    has(key) {

        return key in this.dictionary;

    }

    /*=====================================================
      ADD
    =====================================================*/

    add(language, dictionary) {

        this.languages.set(

            language,

            dictionary

        );

    }

    /*=====================================================
      EXPORT
    =====================================================*/

    export() {

        return JSON.stringify(

            this.dictionary,

            null,

            2

        );

    }

    /*=====================================================
      IMPORT
    =====================================================*/

    import(language, json) {

        this.languages.set(

            language,

            json

        );

    }

    /*=====================================================
      DETECT
    =====================================================*/

    detect() {

        const lang =

            navigator.language ||

            this.defaultLanguage;

        return this.available()

            .find(

                l =>

                l.code === lang

            )

            ?.code ||

            this.defaultLanguage;

    }

}

const i18n = new I18n();

export default i18n;
